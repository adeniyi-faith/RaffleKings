<script>
    const amountInput = document.getElementById('withdraw-amount');
    const displayEarnings = document.getElementById('display-earnings');
    const accountContainer = document.getElementById('account-select-container');
    const withdrawBtn = document.getElementById('withdraw-btn');
    const selectedAccountId = document.getElementById('selected-account-id');

    let currentEarnings = 0;
    let accounts = [];

    document.addEventListener('DOMContentLoaded', async () => {
        const token = localStorage.getItem('token');

        // 1. Load Balance
        currentEarnings = parseFloat(localStorage.getItem('earningsBalance') || 0);
        displayEarnings.innerText = '₦' + currentEarnings.toLocaleString();

        // Refresh Balance from API
        try {
            const res = await fetch(((typeof API_CONFIG !== 'undefined' && API_CONFIG.BALANCE) ? API_CONFIG.BALANCE : 'ajax-router.php?action=get_balance'), {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if(res.ok) {
                const data = await res.json();
                currentEarnings = parseFloat(data.earnings); // Changed to earnings
                displayEarnings.innerText = '₦' + currentEarnings.toLocaleString();
                localStorage.setItem('earningsBalance', currentEarnings);
            }
        } catch(e) {}

        // 2. Load Bank Accounts
        try {
            const res = await fetch(((typeof API_CONFIG !== 'undefined' && API_CONFIG.BANK_ACCOUNTS) ? API_CONFIG.BANK_ACCOUNTS : 'ajax-router.php?action=bank_accounts'), {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            accounts = await res.json();
            renderAccounts(accounts);
        } catch(e) {
            accountContainer.innerHTML = '<p class="text-xs text-red-500">Failed to load accounts.</p>';
        }

        lucide.createIcons();
    });

    function renderAccounts(data) {
        if (!data || data.length === 0) {
            accountContainer.innerHTML = `
                <a href="bank-details.php" class="block w-full border-2 border-dashed border-gray-300 dark:border-gray-700 rounded-xl p-4 text-center text-gray-400 dark:text-gray-500 text-sm font-bold hover:border-app-primary hover:text-app-primary dark:hover:border-app-primary dark:hover:text-app-primary transition-colors bg-gray-50 dark:bg-gray-800/50">
                    + Add Bank Account
                </a>
            `;
            withdrawBtn.disabled = true;
            return;
        }

        // Auto-select primary
        const primary = data.find(a => a.is_primary) || data[0];
        selectedAccountId.value = primary.id;
        withdrawBtn.disabled = false;

        const initial = primary.bank_name.substring(0, 2).toUpperCase();

        accountContainer.innerHTML = `
            <div class="bg-white dark:bg-dark-card border border-green-200 dark:border-green-900/50 p-4 rounded-xl flex items-center gap-4 shadow-sm relative overflow-hidden transition-colors">
                <div class="absolute top-0 left-0 bg-green-500 text-white text-[9px] font-bold px-2 py-0.5 rounded-br-lg">SELECTED</div>
                <div class="w-10 h-10 rounded-full bg-gray-50 dark:bg-gray-800 flex items-center justify-center text-gray-600 dark:text-gray-300 font-bold text-xs border border-gray-100 dark:border-gray-700 mt-2">
                    ${initial}
                </div>
                <div class="flex-1 mt-2">
                    <h4 class="font-bold text-gray-900 dark:text-white text-sm">${primary.bank_name}</h4>
                    <p class="text-xs text-gray-500 dark:text-gray-400">${primary.account_name} • ${primary.account_number}</p>
                </div>
                <div class="w-6 h-6 rounded-full bg-green-100 dark:bg-green-900/40 flex items-center justify-center mt-2">
                    <i data-lucide="check" class="w-3 h-3 text-green-600 dark:text-green-400 stroke-[3]"></i>
                </div>
            </div>
        `;
        lucide.createIcons();
    }

    function setAmount(val) {
        amountInput.value = val;
    }

    function setMaxAmount() {
        amountInput.value = currentEarnings;
    }

    async function processWithdrawal() {
        const amount = parseFloat(amountInput.value);
        const accountId = selectedAccountId.value;
        const btn = document.getElementById('withdraw-btn');
        const token = localStorage.getItem('token');

        // Validation
        if (!amount || amount < 2000) {
            alert("Minimum withdrawal is ₦2,000");
            return;
        }
        if (amount > currentEarnings) {
            alert("Insufficient earnings.");
            return;
        }
        if (!accountId) {
            alert("Please select a bank account.");
            return;
        }

        // Loading State
        const originalText = btn.innerHTML;
        btn.innerHTML = '<span class="animate-spin mr-2"><i data-lucide="loader-2" class="w-4 h-4"></i></span> Processing...';
        btn.disabled = true;
        lucide.createIcons();

        try {
            const res = await fetch(((typeof API_CONFIG !== 'undefined' && API_CONFIG.WITHDRAW) ? API_CONFIG.WITHDRAW : 'ajax-router.php?action=withdrawal'), {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ amount: amount, account_id: accountId })
            });

            const data = await res.json();

            // *** HANDLE SUCCESS ***
            if (res.ok && data.success) {
                // Update Local Balance
                localStorage.setItem('earningsBalance', data.new_earnings);
                document.getElementById('confirm-amount').innerText = amount.toLocaleString();

                // Show Success Modal
                document.getElementById('success-modal').classList.remove('hidden');
                setTimeout(() => {
                    document.getElementById('modal-content').classList.remove('scale-90', 'opacity-0');
                    document.getElementById('modal-content').classList.add('scale-100', 'opacity-100');
                }, 10);

            // *** HANDLE SPECIFIC ERROR: DEPOSIT LIMIT ***
            } else if (data.code === 'deposit_limit') {
                document.getElementById('verify-modal').classList.remove('hidden');

            // *** GENERIC ERROR ***
            } else {
                alert(data.message || "Withdrawal Failed");
            }

        } catch (e) {
            console.error(e);
            alert("Network Error. Please try again.");
        } finally {
            btn.innerHTML = originalText;
            if (currentEarnings >= 2000) btn.disabled = false;
            lucide.createIcons();
        }
    }
</script>

